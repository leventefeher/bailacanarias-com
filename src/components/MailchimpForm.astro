---
interface Props {
  lang?: 'en' | 'es';
  actionUrl?: string;
}

const {
  lang = 'en',
  actionUrl = 'https://bailacanarias.us21.list-manage.com/subscribe/post?u=6eb20492e217d3d8c4d8b0b7f&id=3ccaf47767&v_id=340&f_id=0004bde6f0',
} = Astro.props;

const t = {
  en: {
    heading: "Let's keep in touch",
    sub: "Sign up for our mailing list to hear about upcoming classes, courses, parties and events. We take your privacy seriously and will never spam you.",
    firstName: 'First Name',
    email: 'Email',
    role: 'Main dance role',
    rolePlaceholder: 'Select...',
    leader: 'Leader',
    follower: 'Follower',
    styles: 'Styles interested in',
    subscribe: 'Subscribe',
    loading: 'Subscribing…',
    privacy: 'You can unsubscribe at any time.',
    success: "You're subscribed! Check your inbox to confirm.",
    error: 'Something went wrong. Please try again.',
    alreadySubscribed: "You're already subscribed.",
  },
  es: {
    heading: 'Mantengámonos en contacto',
    sub: 'Suscríbete a nuestra lista de correo para enterarte de próximas clases, cursos, fiestas y eventos. Nos tomamos muy en serio tu privacidad.',
    firstName: 'Nombre',
    email: 'Correo electrónico',
    role: 'Rol principal',
    rolePlaceholder: 'Seleccionar...',
    leader: 'Leader',
    follower: 'Follower',
    styles: 'Estilos de interés',
    subscribe: 'Suscribirse',
    loading: 'Suscribiendo…',
    privacy: 'Puedes darte de baja en cualquier momento.',
    success: '¡Te has suscrito! Revisa tu bandeja de entrada para confirmar.',
    error: 'Algo salió mal. Por favor, inténtalo de nuevo.',
    alreadySubscribed: 'Ya estás suscrito.',
  },
};

const text = t[lang];
---

<section class="section mc-section">
  <div class="container">
    <div class="mc-form-wrap">
      <h2>{text.heading}</h2>
      <p class="subtitle">{text.sub}</p>

      <form
        action={actionUrl}
        method="post"
        id="mc-embedded-subscribe-form"
        name="mc-embedded-subscribe-form"
        class="mc-form"
        novalidate
        data-success={text.success}
        data-error={text.error}
        data-already={text.alreadySubscribed}
        data-loading={text.loading}
      >
        <div class="form-row">
          <div class="form-group">
            <label for="mce-FNAME">{text.firstName}</label>
            <input type="text" name="FNAME" id="mce-FNAME" autocomplete="given-name" />
          </div>
          <div class="form-group">
            <label for="mce-EMAIL">{text.email} *</label>
            <input type="email" name="EMAIL" id="mce-EMAIL" required autocomplete="email" />
          </div>
        </div>

        <div class="form-group">
          <label for="mce-ROLE">{text.role}</label>
          <select name="ROLE" id="mce-ROLE">
            <option value="">{text.rolePlaceholder}</option>
            <option value="Leader">{text.leader}</option>
            <option value="Follower">{text.follower}</option>
          </select>
        </div>

        <div>
          <span class="checkboxes-label">{text.styles}</span>
          <div class="checkboxes">
            <label>
              <input type="checkbox" name="group[STYLES][1]" value="1" /> Salsa
            </label>
            <label>
              <input type="checkbox" name="group[STYLES][2]" value="2" /> Bachata
            </label>
            <label>
              <input type="checkbox" name="group[STYLES][4]" value="4" /> Kizomba
            </label>
          </div>
        </div>

        <!-- MailChimp bot protection — do not remove -->
        <div style="position:absolute;left:-5000px;" aria-hidden="true">
          <input type="text" name="b_6eb20492e217d3d8c4d8b0b7f_3ccaf47767" tabindex="-1" value="" />
        </div>

        <div id="mc-status" role="alert" aria-live="polite" style="display:none;text-align:center;font-weight:600;padding:0.75rem;border-radius:6px;margin-top:0.5rem;"></div>

        <button type="submit" name="subscribe" class="btn btn-primary">{text.subscribe}</button>

        <p style="text-align:center;font-size:0.8rem;color:rgba(255,255,255,0.9);margin-top:0.25rem;">
          {text.privacy}
        </p>
      </form>
    </div>
  </div>
</section>

<style>
  @keyframes mc-spin {
    to { transform: rotate(360deg); }
  }
</style>

<script is:inline>
  (function () {
    var form = document.getElementById('mc-embedded-subscribe-form');
    if (!form) return;

    form.addEventListener('submit', function (e) {
      e.preventDefault();

      var statusEl = document.getElementById('mc-status');
      var btn = form.querySelector('button[type="submit"]');
      var successMsg = form.dataset.success || 'Subscribed!';
      var errorMsg = form.dataset.error || 'Something went wrong.';
      var alreadyMsg = form.dataset.already || "You're already subscribed.";
      var loadingMsg = form.dataset.loading || 'Subscribing…';

      // Swap /post → /post-json for JSONP
      var jsonpUrl = form.action.replace('/post?', '/post-json?');

      // Serialise form data manually (avoids TS cast issues)
      var formData = new FormData(form);
      var params = new URLSearchParams();
      formData.forEach(function (value, key) {
        params.append(key, String(value));
      });

      var callbackName = '__mcCallback_' + Date.now();
      var src = jsonpUrl + '&' + params.toString() + '&c=' + callbackName;

      // Loading state
      var originalLabel = btn.textContent;
      btn.disabled = true;
      btn.innerHTML =
        '<svg style="display:inline-block;vertical-align:middle;margin-right:6px;animation:mc-spin 0.8s linear infinite" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round"><path d="M12 2v4M12 18v4M4.93 4.93l2.83 2.83M16.24 16.24l2.83 2.83M2 12h4M18 12h4M4.93 19.07l2.83-2.83M16.24 7.76l2.83-2.83"/></svg>'
        + loadingMsg;

      // Register callback on window so JSONP response can find it
      window[callbackName] = function (data) {
        btn.disabled = false;
        btn.textContent = originalLabel;
        statusEl.style.display = 'block';
        if (data.result === 'success') {
          statusEl.style.background = 'rgba(255,255,255,0.15)';
          statusEl.style.color = '#fff';
          statusEl.textContent = successMsg;
          form.reset();
        } else if (data.msg && data.msg.includes('already subscribed')) {
          statusEl.style.background = 'rgba(255,255,255,0.15)';
          statusEl.style.color = '#fff';
          statusEl.textContent = alreadyMsg;
        } else {
          statusEl.style.background = 'rgba(255,100,100,0.3)';
          statusEl.style.color = '#fff';
          statusEl.textContent = errorMsg;
        }
        // Tidy up
        delete window[callbackName];
        var scriptEl = document.getElementById(callbackName);
        if (scriptEl) scriptEl.remove();
      };

      var script = document.createElement('script');
      script.id = callbackName;
      script.src = src;
      document.body.appendChild(script);
    });
  })();
</script>
