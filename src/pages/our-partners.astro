---
import Layout from '../layouts/Layout.astro';
import MailchimpForm from '../components/MailchimpForm.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const data = await reader.singletons.partners.read();
const partnersList = data?.partners ?? [];
---

<Layout
  title="Our Partners"
  description="Organisations we work with and recommend in Tenerife — partners of Baila Canarias dance school."
  lang="en"
  hreflangEN="https://www.bailacanarias.com/our-partners"
  hreflangES="https://www.bailacanarias.com/es/nuestros-socios"
>
  <div class="page-header" style={`--page-hero-img: url('${data?.heroImage ?? '/images/2023/12/320A0424.jpg'}')`}>
    <div class="container">
      <h1>Our partners</h1>
      <p>Organisations we work with and recommend in Tenerife</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <p style="font-size:1.05rem;max-width:700px;margin-bottom:3rem;">
        {data?.introEn} If you would like to partner with us or collaborate in some way,
        <a href="/contact">get in contact with us</a>.
      </p>

      <div class="cards-grid" style="grid-template-columns:repeat(auto-fit,minmax(300px,1fr));">
        {
          partnersList.map((partner) => (
            <div class="card card-accent">
              <h3>{partner.name}</h3>
              <p>{partner.descriptionEn}</p>
            </div>
          ))
        }
      </div>

      <div style="text-align:center;margin-top:3rem;">
        <h2 style="margin-bottom:1rem;">Interested in working together?</h2>
        <p style="max-width:500px;margin:0 auto 1.5rem;">
          Are you interested in working with us or collaborating in some way? Get in touch now.
        </p>
        <a href="/contact" class="btn btn-primary">Contact Baila Canarias</a>
      </div>
    </div>
  </section>

  <MailchimpForm lang="en" />
</Layout>
