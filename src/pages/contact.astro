---
import Layout from '../layouts/Layout.astro';
import MailchimpForm from '../components/MailchimpForm.astro';
---

<Layout
  title="Contact Baila Canarias"
  description="Get in touch with Baila Canarias. Find us on Instagram, Facebook, or WhatsApp."
  lang="en"
  hreflangEN="https://www.bailacanarias.com/contact"
  hreflangES="https://www.bailacanarias.com/es/"
>
  <div class="page-header">
    <div class="container">
      <h1>Contact Baila Canarias</h1>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div style="max-width:700px;margin:0 auto;">
        <p style="font-size:1.05rem;margin-bottom:2.5rem;">
          If you would like to get in touch with us you can do so on our Instagram and Facebook
          pages, or by messaging us on WhatsApp or SMS.
        </p>

        <div class="cards-grid" style="grid-template-columns:repeat(auto-fit,minmax(200px,1fr));gap:1.5rem;">
          <a href="https://www.instagram.com/bailacanarias" target="_blank" rel="noopener" class="card" style="text-decoration:none;text-align:center;">
            <div style="margin-bottom:0.75rem;color:var(--color-primary);">
              <svg width="36" height="36" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/></svg>
            </div>
            <h3 style="color:var(--color-heading);">Instagram</h3>
            <p style="font-size:0.9rem;">@bailacanarias</p>
          </a>

          <a href="https://www.facebook.com/bailacanarias" target="_blank" rel="noopener" class="card" style="text-decoration:none;text-align:center;">
            <div style="margin-bottom:0.75rem;color:var(--color-primary);">
              <svg width="36" height="36" fill="currentColor" viewBox="0 0 24 24"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            </div>
            <h3 style="color:var(--color-heading);">Facebook</h3>
            <p style="font-size:0.9rem;">bailacanarias</p>
          </a>

          <a href="https://wa.me/34629178242" target="_blank" rel="noopener" class="card" style="text-decoration:none;text-align:center;">
            <div style="margin-bottom:0.75rem;color:var(--color-primary);">
              <svg width="36" height="36" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413Z"/></svg>
            </div>
            <h3 style="color:var(--color-heading);">WhatsApp / SMS</h3>
            <p style="font-size:0.9rem;">+34 629 17 82 42</p>
          </a>

          <a href="mailto:contact@bailacanarias.com" class="card" style="text-decoration:none;text-align:center;">
            <div style="margin-bottom:0.75rem;color:var(--color-primary);">
              <svg width="36" height="36" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
            </div>
            <h3 style="color:var(--color-heading);">Email</h3>
            <p style="font-size:0.9rem;">contact@bailacanarias.com</p>
          </a>
        </div>

        <div style="background:var(--color-bg-light);border-radius:8px;padding:1.5rem 2rem;margin-top:2.5rem;">
          <p style="margin:0;font-size:0.95rem;">
            <strong>Where to find us:</strong><br/>
            B-Yard Food Court, Puerto Santiago, Tenerife<br/>
            Classes also held in Los Gigantes, Tenerife
          </p>
        </div>
      </div>
    </div>
  </section>

  <MailchimpForm lang="en" />
</Layout>
