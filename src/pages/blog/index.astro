---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const posts = (await getCollection('blog', ({ data }) => !data.draft && data.lang === 'en'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<Layout
  title="Latin Dance Blog"
  description="Articles, tips and guides about salsa, bachata, kizomba and Latin dance culture from the teachers at Baila Canarias Dance Academy, Tenerife."
  lang="en"
>
  <div class="page-header">
    <div class="container">
      <h1>Blog</h1>
      <p>Dance tips, culture and news from Baila Canarias</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      {posts.length === 0 ? (
        <p style="text-align:center;color:var(--color-text);font-size:1.05rem;">
          Blog posts coming soon. <a href="/contact/">Get in touch</a> if you have suggestions!
        </p>
      ) : (
        <div class="blog-grid">
          {posts.map(post => (
            <article class="blog-card">
              <div class="blog-card-body">
                <div class="blog-meta">
                  {post.data.pubDate.toLocaleDateString('en-GB', { year: 'numeric', month: 'long', day: 'numeric' })}
                  {post.data.author && ` · ${post.data.author}`}
                </div>
                <h2><a href={`/blog/${post.slug}`}>{post.data.title}</a></h2>
                <p style="font-size:0.95rem;">{post.data.description}</p>
                <a href={`/blog/${post.slug}`} style="font-weight:600;font-size:0.9rem;">Read more →</a>
              </div>
            </article>
          ))}
        </div>
      )}
    </div>
  </section>
</Layout>
