---
import Layout from '../../layouts/Layout.astro';
import MailchimpForm from '../../components/MailchimpForm.astro';
import { createReader } from '@keystatic/core/reader';
import keystaticConfig from '../../../keystatic.config';

const reader = createReader(process.cwd(), keystaticConfig);
const data = await reader.singletons.classes.read();
const classes = data?.classes ?? [];
---

<Layout
  title="Clases y Cursos de Baile Latino en Tenerife"
  description="Únete a las clases grupales de salsa, bachata y kizomba de Baila Canarias Dance Academy en Puerto Santiago, Tenerife. Principiantes y todos los niveles bienvenidos."
  lang="es"
  hreflangEN="https://www.bailacanarias.com/dance-with-us"
  hreflangES="https://www.bailacanarias.com/es/aprende-a-bailar-con-nosotros"
>
  <div class="page-header" style={`--page-hero-img: url('${data?.heroImage ?? '/images/2024/09/Nadina-Levente-Demo-e1726400010348.jpg'}')`}>
    <div class="container">
      <h1>Aprende a bailar con nosotros</h1>
      <p>Clases de salsa, bachata y kizomba, talleres, cursos, clases privadas y más.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <p style="font-size:1.05rem;max-width:700px;margin-bottom:3rem;">
        {data?.introEs}
      </p>

      <h2 style="margin-bottom:2rem;">Clases y Cursos Actuales</h2>

      <div class="cards-grid" style="grid-template-columns:repeat(auto-fit,minmax(320px,1fr));">
        {
          classes.map((cls) => (
            <div class="card card-accent">
              <div style="display:flex;align-items:center;gap:0.75rem;margin-bottom:1rem;">
                <span style="background:var(--color-primary);color:white;padding:0.35rem 0.75rem;border-radius:20px;font-size:0.8rem;font-weight:700;">
                  {cls.dayEs}
                </span>
                <span style="background:#f0f0f0;color:var(--color-heading);padding:0.35rem 0.75rem;border-radius:20px;font-size:0.8rem;font-weight:600;">
                  {cls.levelEs}
                </span>
              </div>
              <h3>{cls.titleEs}</h3>
              {cls.descriptionEs.split('\n\n').map((para) => (
                <p set:html={para} />
              ))}
              {cls.priceEs && (
                <p style="font-weight:700;color:var(--color-heading);">{cls.priceEs}</p>
              )}
              {cls.promoEs && (
                <p style="color:var(--color-primary);font-weight:600;font-size:0.9rem;">{cls.promoEs}</p>
              )}
              {!cls.priceEs && (
                <p style="font-style:italic;font-size:0.9rem;">¡Bienvenidos a unirse! Para cualquier pregunta contáctanos.</p>
              )}
              <div style="margin-top:1rem;display:flex;gap:0.75rem;flex-wrap:wrap;">
                <a href="mailto:contact@bailacanarias.com" class="btn btn-primary" style="font-size:0.85rem;padding:0.5rem 1rem;">Escríbenos</a>
                <a href="tel:+34629178242" class="btn btn-outline-primary" style="font-size:0.85rem;padding:0.5rem 1rem;">+34 629 17 82 42</a>
              </div>
            </div>
          ))
        }
      </div>

      <div style="background:var(--color-bg-light);border-radius:8px;padding:1.5rem;margin-top:2rem;">
        <p style="margin:0;font-size:0.95rem;">
          <strong>¿Buscas clases privadas, talleres o quieres informarte sobre próximos cursos?</strong><br/>
          Contáctanos directamente en
          <a href="mailto:contact@bailacanarias.com">contact@bailacanarias.com</a> o
          <a href="tel:+34629178242">+34 629 17 82 42</a>.
        </p>
      </div>
    </div>
  </section>

  <MailchimpForm lang="es" />
</Layout>
